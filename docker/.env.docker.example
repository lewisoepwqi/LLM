# Docker 部署变量示例（Linux GPU 服务器）
# 复制为 deploy/docker/.env，docker compose 会自动读取。
#
#   cp .env.docker.example .env
#
# 推荐自包含布局（与合同业务解耦）：
#   ~/app/LLM/
#     docker/   <- 本目录（compose 在这里跑）
#     models/   <- GGUF 放这里
# 此时 MODELS_DIR 用相对路径 ../models 即可（相对 compose 文件所在目录解析）。

# 宿主机模型目录，会被只读挂载到容器内 /models。
# 自包含布局用 ../models；放别处就写绝对路径，如 /home/ubuntu/app/LLM/models。
MODELS_DIR=../models

# 相对 /models 的模型文件路径（容器内路径 = /models/${MODEL_FILE}）。
MODEL_FILE=Qwen3.5-9B/Qwen_Qwen3.5-9B-Q5_K_M.gguf

# 暴露到宿主机的端口（容器内固定 8080）。
LLAMA_SERVER_PORT=8080

# 使用哪张 GPU。先单卡：0。第二张卡：1。
GPU_DEVICE_ID=0

# 上卡层数。9B 在 A4000(16GB) 可全量 offload，99 = 全部进显存。
N_GPU_LAYERS=99

# 上下文长度。显存吃紧可降到 4096。
CONTEXT_SIZE=8192
